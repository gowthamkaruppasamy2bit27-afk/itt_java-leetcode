class Solution {
    public boolean isPalindrome(int x) {
 
        if (x < 0 || (x % 10 == 0 && x!=0)) {
            return false;
        }

        int re = 0;
   
        while (x > re) {
            int last = x % 10;
            re = (re * 10) + last;
            x /= 10; 
        }
        return x == re || x == re / 10;
    }
}
